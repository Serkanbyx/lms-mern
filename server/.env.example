# =====================================================================
# LMS Server — Environment Variables (EXAMPLE)
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in REAL values for local dev.
# NEVER commit `.env`. Only this `.env.example` (with placeholders) is
# tracked in git. Production values live on Render dashboard.
#
# Validation rules enforced at startup by `server/config/env.js`:
#   - In production, JWT_ACCESS_SECRET and JWT_REFRESH_SECRET must each
#     be at least 32 characters and must differ from each other.
#   - In production, CLIENT_URL / CORS_ORIGINS must NOT contain "*".
#   - In production, all CLOUDINARY_* values are required.
#   - MONGO_URI must start with "mongodb://" or "mongodb+srv://".
#   - BCRYPT_ROUNDS must be an integer between 10 and 14.
# =====================================================================

# --- Runtime ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017/lms_dev

# --- JWT (access + rotating refresh tokens) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex
JWT_REFRESH_EXPIRES_IN=7d

# --- Cloudinary (video / image hosting + HLS adaptive streaming) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Mail (password reset, email verification) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
MAIL_FROM="LMS Platform <no-reply@example.com>"

# --- Redis (horizontal scalability) ---
# Optional. When set, the rate limiter uses a shared Redis store so multiple
# API instances share one bucket per (limiter, key) — without this, each
# instance keeps its own counter and effectively multiplies the cap by the
# replica count. Leave unset for local dev (the limiter falls back to an
# in-memory store automatically).
#
# Local: `docker run --rm -p 6379:6379 redis:alpine`
# Render: provision the smallest managed Redis tier and paste its URL here.
REDIS_URL=redis://127.0.0.1:6379

# --- Initial admin (used by `npm run seed:admin`) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_locally_min_12_chars
ADMIN_NAME=Platform Admin

# --- CORS allowlist (comma separated; CLIENT_URL is auto-included) ---
CORS_ORIGINS=http://localhost:5173

# --- Hashing ---
BCRYPT_ROUNDS=12

# --- Account lockout ---
# After MAX_LOGIN_ATTEMPTS consecutive failed logins the account locks for
# LOCK_DURATION_MIN minutes. Generic "Invalid email or password" is preserved
# regardless of the lock state to avoid user enumeration.
MAX_LOGIN_ATTEMPTS=10
LOCK_DURATION_MIN=15

# --- Email verification & password reset TTLs ---
EMAIL_VERIFICATION_TTL_MIN=1440
PASSWORD_RESET_TTL_MIN=15

# --- Refresh-token cookie name (Option A — HttpOnly cookie) ---
REFRESH_COOKIE_NAME=lms.refresh

# --- Logging ---
LOG_LEVEL=info

# --- Feature flags ---
# Server-side mirror of `client/src/config/features.js`. The CLIENT
# variants are prefixed `VITE_FEATURE_*` and live in `client/.env`.
# Both sides MUST default to the same value or you'll ship "button is
# there but the API 404s" bugs.
FEATURE_CERTIFICATES=true
FEATURE_HLS=false
FEATURE_BETA_QUIZ_TIMER=false
