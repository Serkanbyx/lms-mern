# =====================================================================
# LMS Server — Environment Variables (EXAMPLE)
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in REAL values for local dev.
# NEVER commit `.env`. Only this `.env.example` (with placeholders) is
# tracked in git. Production values live on Render dashboard.
#
# Validation rules enforced at startup by `server/config/env.js`:
#   - In production, JWT_ACCESS_SECRET and JWT_REFRESH_SECRET must each
#     be at least 32 characters and must differ from each other.
#   - In production, CLIENT_URL / CORS_ORIGINS must NOT contain "*".
#   - In production, all CLOUDINARY_* values are required.
#   - MONGO_URI must start with "mongodb://" or "mongodb+srv://".
#   - BCRYPT_ROUNDS must be an integer between 10 and 14.
# =====================================================================

# --- Runtime ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# --- Database ---
MONGO_URI=mongodb://127.0.0.1:27017/lms_dev

# --- JWT (access + rotating refresh tokens) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex
JWT_REFRESH_EXPIRES_IN=7d

# --- Cloudinary (video / image hosting + HLS adaptive streaming) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Mail (password reset, email verification) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
MAIL_FROM="LMS Platform <no-reply@example.com>"

# --- Redis (rate limiting + token revocation cache) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Initial admin (used by `npm run seed:admin`) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_locally_min_12_chars
ADMIN_NAME=Platform Admin

# --- CORS allowlist (comma separated; CLIENT_URL is auto-included) ---
CORS_ORIGINS=http://localhost:5173

# --- Hashing ---
BCRYPT_ROUNDS=12

# --- Logging ---
LOG_LEVEL=info
