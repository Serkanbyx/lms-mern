# =====================================================================
# LMS Client — Environment Variables (EXAMPLE)
# ---------------------------------------------------------------------
# Copy this file to `.env` and fill in real values for local dev.
# Vite exposes ONLY variables prefixed with `VITE_` to the browser bundle.
# NEVER put server secrets here — anything in this file is shipped to the
# client and is publicly visible.
# =====================================================================

# Base URL of the Express API (no trailing slash).
# Every request issued through `src/api/axios.js` is prefixed with this.
VITE_API_BASE_URL=http://localhost:5000/api

# Public site URL (used in SEO / Open Graph metadata + share links).
VITE_SITE_URL=http://localhost:5173

# App display name (footer, meta tags, manifest fallback).
VITE_APP_NAME=Lumen LMS

# --- Feature flags (STEP 49) ---
# Mirror `FEATURE_*` in `server/.env`. The server flag is the
# security-critical one (gates the route); these client flags just
# hide the UI affordance so users don't see a button that 404s.
#
# Conventions:
#   - Defaults assume "feature ON" unless explicitly "false".
#   - Beta flags default OFF unless explicitly "true".
VITE_FEATURE_CERTIFICATES=true
VITE_FEATURE_HLS=false
VITE_FEATURE_COMMAND_PALETTE=true
VITE_FEATURE_BETA_QUIZ_TIMER=false
VITE_FEATURE_ANALYTICS=false
